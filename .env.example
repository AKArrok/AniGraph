# ── LLM (DeepSeek / OpenAI 兼容协议) ───────────────────────────
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
SIMPLE_LLM_MODEL=deepseek-v4-flash

# ── Embeddings ────────────────────────────────────────────────────
# 后端: "local"=HuggingFace本地模型(零API费用) | "dashscope"=阿里云API
EMBEDDING_BACKEND=local
# 本地模型（首次运行自动从 HuggingFace 下载，也可指定本地路径）
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# 运行设备: auto=自动检测CUDA | cpu=强制CPU | cuda=强制GPU
LOCAL_EMBEDDING_DEVICE=auto
# HuggingFace 镜像（国内加速，可选）
# HF_ENDPOINT=https://hf-mirror.com
# DashScope 模型（仅 EMBEDDING_BACKEND=dashscope 时生效）
# DASHSCOPE_API_KEY=your_dashscope_api_key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v4

# ── Vector DB (Pinecone) ──────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=vector

# ── Web Search (Tavily) ───────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key

# ── Observability — LangSmith (optional) ────────────────────────────
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=langgraph-agent
# LANGCHAIN_TRACING_V2=false

# ── Agent Tuning — optional ───────────────────────────────────────
MAX_ITERATIONS=3
RETRIEVER_K=5
RETRIEVER_FETCH_K=20

# ── Short-term Memory ──────────────────────────────────────────
MEMORY_MAX_ROUNDS=10
